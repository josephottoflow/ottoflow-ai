{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/deploy-guard.sh\"",
            "timeout": 30,
            "statusMessage": "Verifying GitHub identity before deploy/publish…"
          }
        ]
      }
    ]
  }
}
