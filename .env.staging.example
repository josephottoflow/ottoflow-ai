# Phase 2A staging — copy to .env.staging and fill in. STAGING ONLY.
# The harness refuses to run if NEXT_PUBLIC_SUPABASE_URL points at prod (ddozknywcdpyfdokmfrp).
NEXT_PUBLIC_SUPABASE_URL=https://<your-staging-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging service_role key>
REDIS_URL=rediss://<dedicated staging redis>
GOOGLE_API_KEY=<Imagen-4.0-enabled key>
# R2 intentionally unset — image acceptance test uses Supabase Storage.
