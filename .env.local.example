# ============================================================================
# Ottoflow AI — environment template
# ============================================================================
#
# Copy this file to `.env.local` and fill in the missing values. Both the
# Next.js app and the BullMQ worker read from `.env.local` in development.
#
# In production, set these directly in the platform dashboard
# (Vercel for the web app, Railway for the worker). DO NOT commit secrets.
#
# Env values are validated at process startup by:
#   - src/lib/env.ts          → Next.js app  (NEXT_PUBLIC_* + server secrets)
#   - src/lib/worker-env.ts   → BullMQ worker (Supabase + Redis + Gemini)
#
# Missing/invalid values cause a loud startup failure with a clear message.
# See docs/DEPLOYMENT.md for per-platform setup steps and troubleshooting.
# ============================================================================


# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/<your-project>/settings/api
#
# Required by: Next.js + Worker
# Used for:    Database, Realtime, RLS (via Clerk JWT bridge)

# Public REST URL (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon (publishable) key — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — bypasses RLS; SERVER-SIDE ONLY (worker + API routes)
SUPABASE_SERVICE_ROLE_KEY=


# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com  →  API Keys
#
# Required by: Next.js
# Used for:    Sign-in/sign-up, session JWT, Supabase RLS bridge

# Publishable key (pk_test_… or pk_live_…) — safe in the browser
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Secret key (sk_test_… or sk_live_…) — server-only
CLERK_SECRET_KEY=

# Optional — override Clerk redirect paths (defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/


# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
# Required by: Next.js (enqueue) + Worker (consume)
# Used for:    Background job queue
#
# Local options:
#   redis://localhost:6379                (brew / Memurai / Docker)
# Hosted (recommended for production):
#   rediss://default:<password>@<host>.upstash.io:<port>   (Upstash, TLS)

REDIS_URL=


# ─── Google AI (Gemini) ──────────────────────────────────────────────────────
# Dashboard: https://aistudio.google.com/app/apikey
#
# Required by: Worker
# Used for:    Brand research (extraction, competitor search, SEO bundle)

GOOGLE_API_KEY=

# Optional — Gemini model (default: gemini-2.5-flash, cheap + grounding tools)
# GEMINI_MODEL=gemini-2.5-flash

# Optional — per-Gemini-call hard timeout in ms (default: 90000)
# GEMINI_TIMEOUT_MS=90000


# ─── Worker tuning ───────────────────────────────────────────────────────────
# Required by: Worker
# All optional with sensible defaults.

# Number of concurrent jobs per worker process (default: 2)
# WORKER_CONCURRENCY=2

# Log level — trace | debug | info | warn | error | fatal  (default: info)
# LOG_LEVEL=info


# ─── Legacy bridge (root TikTok-factory app) ─────────────────────────────────
# Only used by /api/generate (deprecated route). Safe to leave blank in prod
# until the video pipeline subsystem is built out.
PIPELINE_API_URL=http://localhost:3000/api/generate
